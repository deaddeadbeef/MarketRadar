CATALYST_ENV=local
CATALYST_DATABASE_URL=sqlite:///data/local/catalyst_radar.db
CATALYST_LOG_LEVEL=INFO
CATALYST_MARKET_PROVIDER=polygon
CATALYST_POLYGON_API_KEY=
CATALYST_POLYGON_BASE_URL=https://api.polygon.io
CATALYST_SEC_ENABLE_LIVE=false
CATALYST_SEC_USER_AGENT=
CATALYST_SEC_BASE_URL=https://data.sec.gov
CATALYST_HTTP_TIMEOUT_SECONDS=10
CATALYST_PROVIDER_AVAILABILITY_POLICY=live_fetch
CATALYST_UNIVERSE_NAME=liquid-us
CATALYST_UNIVERSE_MIN_PRICE=5
CATALYST_UNIVERSE_MIN_AVG_DOLLAR_VOLUME=10000000
CATALYST_UNIVERSE_REQUIRE_SECTOR=false
CATALYST_UNIVERSE_INCLUDE_ETFS=false
CATALYST_UNIVERSE_INCLUDE_ADRS=true
CATALYST_SCAN_BATCH_SIZE=500
CATALYST_PRICE_MIN=5
CATALYST_MARKET_CAP_MIN=300000000
CATALYST_AVG_DOLLAR_VOLUME_MIN=10000000
CATALYST_RISK_PER_TRADE_PCT=0.005
CATALYST_MAX_SINGLE_NAME_PCT=0.08
CATALYST_MAX_SECTOR_PCT=0.30
CATALYST_MAX_THEME_PCT=0.35
CATALYST_ENABLE_PREMIUM_LLM=false

SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=
SCHWAB_ENV=production
SCHWAB_BASE_URL=https://api.schwabapi.com
SCHWAB_AUTH_BASE_URL=https://api.schwabapi.com/v1/oauth
SCHWAB_ORDER_SUBMISSION_ENABLED=false
BROKER_TOKEN_ENCRYPTION_KEY=

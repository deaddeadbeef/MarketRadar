# Core
CATALYST_ENV=local
CATALYST_DATABASE_URL=sqlite:///data/local/catalyst_radar.db
CATALYST_LOG_LEVEL=INFO
CATALYST_HTTP_TIMEOUT_SECONDS=10
CATALYST_PROVIDER_AVAILABILITY_POLICY=live_fetch

# Local fixture defaults. These are safe for smoke tests and make no live calls.
CATALYST_MARKET_PROVIDER=csv
CATALYST_DAILY_MARKET_PROVIDER=csv
CATALYST_CSV_SECURITIES_PATH=data/sample/securities.csv
CATALYST_CSV_DAILY_BARS_PATH=data/sample/daily_bars.csv
CATALYST_CSV_HOLDINGS_PATH=data/sample/holdings.csv
CATALYST_DAILY_EVENT_PROVIDER=news_fixture
CATALYST_NEWS_FIXTURE_PATH=data/sample/news_events_aaa.json

# Live market activation. Keep caps low for the first real run.
CATALYST_DAILY_PROVIDER=
CATALYST_DAILY_UNIVERSE=
CATALYST_DAILY_TICKERS=
CATALYST_POLYGON_API_KEY=
CATALYST_POLYGON_BASE_URL=https://api.polygon.io
CATALYST_POLYGON_TICKERS_MAX_PAGES=1
CATALYST_POLYGON_TICKER_SEED_MIN_INTERVAL_SECONDS=900
CATALYST_RADAR_RUN_MIN_INTERVAL_SECONDS=300

# SEC catalyst activation. SEC requires a descriptive User-Agent.
CATALYST_SEC_ENABLE_LIVE=false
CATALYST_SEC_USER_AGENT=
CATALYST_SEC_BASE_URL=https://data.sec.gov
CATALYST_SEC_DAILY_MAX_TICKERS=5

# Universe and scan policy
CATALYST_UNIVERSE_NAME=liquid-us
CATALYST_UNIVERSE_MIN_PRICE=5
CATALYST_UNIVERSE_MIN_AVG_DOLLAR_VOLUME=10000000
CATALYST_UNIVERSE_REQUIRE_SECTOR=false
CATALYST_UNIVERSE_INCLUDE_ETFS=false
CATALYST_UNIVERSE_INCLUDE_ADRS=true
CATALYST_SCAN_BATCH_SIZE=500
CATALYST_PRICE_MIN=5
CATALYST_MARKET_CAP_MIN=300000000
CATALYST_AVG_DOLLAR_VOLUME_MIN=10000000

# Risk policy
CATALYST_RISK_PER_TRADE_PCT=0.005
CATALYST_MAX_SINGLE_NAME_PCT=0.08
CATALYST_MAX_SECTOR_PCT=0.30
CATALYST_MAX_THEME_PCT=0.35

# Daily run controls
CATALYST_WORKER_INTERVAL_SECONDS=86400
CATALYST_WORKER_LOCK_TTL_SECONDS=2700
CATALYST_WORKER_OWNER=
CATALYST_WORKER_LOCK_NAME=daily-run
CATALYST_DAILY_AS_OF=
CATALYST_DECISION_AVAILABLE_AT=
CATALYST_OUTCOME_AVAILABLE_AT=
CATALYST_RUN_LLM=false
CATALYST_LLM_DRY_RUN=true
CATALYST_DRY_RUN_ALERTS=true

# OpenAI/LLM activation. Leave disabled until model, pricing, and budgets are set.
CATALYST_ENABLE_PREMIUM_LLM=false
CATALYST_LLM_PROVIDER=none
CATALYST_LLM_EVIDENCE_MODEL=
CATALYST_LLM_SKEPTIC_MODEL=
CATALYST_LLM_DECISION_CARD_MODEL=
CATALYST_LLM_INPUT_COST_PER_1M=
CATALYST_LLM_CACHED_INPUT_COST_PER_1M=
CATALYST_LLM_OUTPUT_COST_PER_1M=
CATALYST_LLM_PRICING_UPDATED_AT=
CATALYST_LLM_PRICING_STALE_AFTER_DAYS=30
CATALYST_LLM_DAILY_BUDGET_USD=0
CATALYST_LLM_MONTHLY_BUDGET_USD=0
CATALYST_LLM_MONTHLY_SOFT_CAP_PCT=0.80
CATALYST_LLM_TASK_DAILY_CAPS=
OPENAI_API_KEY=
CATALYST_ENABLE_AGENT_SDK=false
CATALYST_AGENT_SDK_MODEL=

# Schwab read-only broker context
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=
SCHWAB_ENV=production
SCHWAB_BASE_URL=https://api.schwabapi.com
SCHWAB_AUTH_BASE_URL=https://api.schwabapi.com/v1/oauth
SCHWAB_ORDER_SUBMISSION_ENABLED=false
SCHWAB_SYNC_MIN_INTERVAL_SECONDS=900
SCHWAB_MARKET_SYNC_MIN_INTERVAL_SECONDS=300
SCHWAB_MARKET_SYNC_MAX_TICKERS=5
BROKER_TOKEN_ENCRYPTION_KEY=

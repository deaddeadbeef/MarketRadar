{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarketRadar Trading Workbench",
  "version": "0.1.0",
  "identifier": "com.marketradar.desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarketRadar Trading Workbench",
        "width": 1420,
        "height": 940,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
